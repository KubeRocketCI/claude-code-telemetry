{
  "title": "Claude Code — Governance & Security",
  "uid": "claude-code-governance",
  "tags": ["claude-code", "otel", "governance", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "label": "Organization",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total, organization_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\"}, project)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "user_email",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total, user_email)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row", "title": "Permission posture",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false, "panels": []
    },
    {
      "type": "stat", "title": "bypassPermissions escalations (range)",
      "description": "Count of claude_code.permission_mode_changed events whose to_mode is bypassPermissions over the range. The single highest-signal security event — a session dropped its guardrails.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [ { "expr": "sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.permission_mode_changed\" | to_mode=\"bypassPermissions\" [$__range])) or vector(0)", "queryType": "instant", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Permission mode changes by target mode",
      "description": "Rate of claude_code.permission_mode_changed events grouped by to_mode (default / plan / acceptEdits / auto / bypassPermissions).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (to_mode) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.permission_mode_changed\" [$__auto]))", "legendFormat": "{{to_mode}}", "refId": "A" } ]
    },
    {
      "type": "logs", "title": "Recent escalations to bypassPermissions",
      "description": "Raw permission_mode_changed events that entered bypassPermissions — who, when, and via what trigger.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none" },
      "targets": [ { "expr": "{service_name=\"claude-code\"} |= \"claude_code.permission_mode_changed\" | to_mode=\"bypassPermissions\"", "refId": "A" } ]
    },
    {
      "type": "row", "title": "Tool permission decisions",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false, "panels": []
    },
    {
      "type": "stat", "title": "Tool denial rate (%)",
      "description": "Share of claude_code.tool_decision events with decision=reject over accept+reject. A control-effectiveness KPI; sustained high denial may indicate misconfigured permissions or risky prompting.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100 } },
      "targets": [ { "expr": "100 * (sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_decision\" | decision=\"reject\" [$__range])) or vector(0)) / sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_decision\" | decision=~\"accept|reject\" [$__range]))", "queryType": "instant", "refId": "A" } ]
    },
    {
      "type": "table", "title": "Tool decisions by tool & outcome",
      "description": "count_over_time of claude_code.tool_decision grouped by tool_name and decision — accept vs reject per tool.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 15 },
      "targets": [ { "expr": "sum by (tool_name, decision) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_decision\" [$__range]))", "queryType": "instant", "refId": "A" } ],
      "transformations": [ { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Value", "desc": true } ] } } ]
    },
    {
      "type": "table", "title": "user_permanent approvals (policy-review candidates)",
      "description": "Tools granted a permanent 'always allow' (source=user_permanent). Repeat standing approvals are candidates for an explicit allow-list / policy review.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 15 },
      "targets": [ { "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_decision\" | source=\"user_permanent\" [$__range]))", "queryType": "instant", "refId": "A" } ],
      "transformations": [ { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Value", "desc": true } ] } } ]
    },
    {
      "type": "row", "title": "Reliability & MCP governance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false, "panels": []
    },
    {
      "type": "timeseries", "title": "API retries exhausted",
      "description": "claude_code.api_retries_exhausted events by model — provider/proxy stability incidents (also visible as wasted spend on the Ops dashboard).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (model) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.api_retries_exhausted\" [$__auto]))", "legendFormat": "{{model}}", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "MCP connection failures by scope",
      "description": "claude_code.mcp_server_connection events with status=failed, grouped by server_scope (user / project / local). Repeated failures flag infra health or an unapproved server.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (server_scope) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.mcp_server_connection\" | status=\"failed\" [$__auto]))", "legendFormat": "{{server_scope}}", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Hook blocking decisions",
      "description": "Sum of num_blocking from claude_code.hook_execution_complete events by hook_event — how often policy hooks actively blocked an action.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (hook_event) (sum_over_time({service_name=\"claude-code\"} |= \"claude_code.hook_execution_complete\" | unwrap num_blocking [$__auto]))", "legendFormat": "{{hook_event}}", "refId": "A" } ]
    },
    {
      "type": "row", "title": "Auth & cost anomalies",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false, "panels": []
    },
    {
      "type": "logs", "title": "Authentication failures",
      "description": "Raw claude_code.auth events with success=false — failed login/logout (error_category only; no raw messages).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none" },
      "targets": [ { "expr": "{service_name=\"claude-code\"} |= \"claude_code.auth\" | success=\"false\"", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Cost rate by user (top 10) — spike watch",
      "description": "Per-user estimated cost rate; sustained spikes flag runaway workflows or misuse. Filtered by the org/project/user variables.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [ { "expr": "topk(10, sum by (user_email) (rate(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", project=~\"$project\", user_email=~\"$user_email\"}[$__rate_interval])))", "legendFormat": "{{user_email}}", "refId": "A" } ]
    }
  ]
}
