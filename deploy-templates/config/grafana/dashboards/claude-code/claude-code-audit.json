{
  "title": "Claude Code — Usage Audit",
  "uid": "claude-code-audit",
  "tags": ["claude-code", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "label": "Organization",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total, organization_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\"}, project)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "jira_epic",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\"}, jira_epic)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "jira_story",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\"}, jira_story)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "user_email",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total, user_email)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_token_usage_tokens_total, model)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat", "title": "Total tokens (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))", "refId": "A" } ]
    },
    {
      "type": "stat", "title": "Total cost USD (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "targets": [ { "expr": "sum(increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))", "refId": "A" } ]
    },
    {
      "type": "stat", "title": "Sessions (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum(increase(claude_code_session_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))", "refId": "A" } ]
    },
    {
      "type": "stat", "title": "Commits (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum(increase(claude_code_commit_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Tokens over time by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{type}}", "refId": "A" } ]
    },
    {
      "type": "piechart", "title": "Tokens by model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [ { "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))", "legendFormat": "{{model}}", "refId": "A" } ]
    },
    {
      "type": "piechart", "title": "Tokens: main vs subagent",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "targets": [ { "expr": "sum by (query_source) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))", "legendFormat": "{{query_source}}", "refId": "A" } ]
    },
    {
      "type": "barchart", "title": "Cost by project & epic (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [ { "expr": "sum by (project, jira_epic) (increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))", "legendFormat": "{{project}} / {{jira_epic}}", "refId": "A" } ]
    },
    {
      "type": "barchart", "title": "Tokens by agent (subagents)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "expr": "sum by (agent_name) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", agent_name!=\"\"}[$__range]))", "legendFormat": "{{agent_name}}", "refId": "A" } ]
    },
    {
      "type": "table", "title": "Tool usage (count by tool) — from events",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 20 },
      "targets": [ { "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | tool_name != `` [$__range]))", "queryType": "instant", "refId": "A" } ],
      "transformations": [ { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Value", "desc": true } ] } } ]
    },
    {
      "type": "table", "title": "Skill activations (real names — incl. project skills)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 20 },
      "targets": [ { "expr": "sum by (skill_name, skill_source) (count_over_time({service_name=\"claude-code\"} | invocation_trigger =~ `.+` [$__range]))", "queryType": "instant", "refId": "A" } ],
      "transformations": [ { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Value", "desc": true } ] } } ]
    },
    {
      "type": "table", "title": "Subagent invocations (count by agent)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 20 },
      "targets": [ { "expr": "sum by (agent_name) (count_over_time({service_name=\"claude-code\"} | agent_name != `` [$__range]))", "queryType": "instant", "refId": "A" } ],
      "transformations": [ { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Value", "desc": true } ] } } ]
    },
    {
      "type": "logs", "title": "Bash tool events (recent) — commands visible via TOOL_DETAILS",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none" },
      "targets": [ { "expr": "{service_name=\"claude-code\"} | tool_name = `Bash`", "refId": "A" } ]
    }
  ]
}
