{
  "title": "Claude Code — Usage Audit",
  "uid": "claude-code-audit",
  "tags": [
    "claude-code",
    "otel"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "label": "Organization",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total, organization_id)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "project",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\"}, project)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "jira_epic",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\"}, jira_epic)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "jira_story",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\"}, jira_story)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "user_email",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total, user_email)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(claude_code_token_usage_tokens_total, model)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Total tokens (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total cost USD (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Sessions (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Commits (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_commit_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens over time by type",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Tokens by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Tokens: main vs subagent",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (query_source) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", model=~\"$model\"}[$__range]))",
          "legendFormat": "{{query_source}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Cost by project & epic (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "expr": "sum by (project, jira_epic) (increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "legendFormat": "{{project}} / {{jira_epic}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Tokens by agent (subagents)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (agent_name) (increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\", agent_name!=\"\"}[$__range]))",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Tool usage (count by tool) — from events",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | tool_name != `` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Invocations"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Invocations",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Skill activations (real names — incl. project skills)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum by (skill_name, skill_source) (count_over_time({service_name=\"claude-code\"} | invocation_trigger =~ `.+` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Activations"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Activations",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Subagent invocations (count by agent)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum by (agent_name) (count_over_time({service_name=\"claude-code\"} | agent_name != `` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Invocations"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Invocations",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "logs",
      "title": "Bash tool events (recent) — commands visible via TOOL_DETAILS",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | tool_name = `Bash`",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Slash-command usage (by command & source)",
      "description": "claude_code.user_prompt events grouped by command_name / command_source (builtin, custom, mcp) — which skills and commands people actually run. Prompt content is never captured.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 39
      },
      "targets": [
        {
          "expr": "sum by (command_name, command_source) (count_over_time({service_name=\"claude-code\"} | event_name = `user_prompt` | command_name != `` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Runs"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Runs",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "logs",
      "title": "File modifications (recent) — Edit/Write/NotebookEdit",
      "description": "tool_result events for file-mutating tools; file paths visible in tool_input via OTEL_LOG_TOOL_DETAILS. Complements the Bash panel for a full change-audit trail.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 8,
        "y": 39
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | event_name = `tool_result` | tool_name =~ `Edit|Write|NotebookEdit`",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Delivery attribution",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Cost & tokens by Jira story (range)",
      "description": "Per-story rollup from api_request events (jira.story is logs-only by the cardinality rule — this is its canonical home). The sprint-level 'what did story Y cost' answer; assumes sessions are tagged via OTEL_RESOURCE_ATTRIBUTES.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 53
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          },
          "links": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost (USD)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (project, jira_epic, jira_story) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap cost_usd [$__range]))",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "expr": "sum by (project, jira_epic, jira_story) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap output_tokens [$__range]))",
          "queryType": "instant",
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Cost (USD)",
              "Value #B": "Output tokens"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Cost (USD)",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Delivery output by project & epic (range)",
      "description": "Raw AI-assisted throughput — commits, pull requests, and lines of code changed — per project/epic. These metrics otherwise appear only as denominators inside cost ratios.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 62
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (project, jira_epic) (increase(claude_code_commit_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "sum by (project, jira_epic) (increase(claude_code_pull_request_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "instant": true,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "sum by (project, jira_epic) (increase(claude_code_lines_of_code_count_total{organization_id=~\"$organization_id\", project=~\"$project\", jira_epic=~\"$jira_epic\", jira_story=~\"$jira_story\", user_email=~\"$user_email\"}[$__range]))",
          "instant": true,
          "format": "table",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Commits",
              "Value #B": "PRs",
              "Value #C": "Lines changed"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Commits",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Unattributed cost (no epic tag)",
      "description": "Spend from sessions with an empty jira_epic label — work the per-epic breakdowns cannot see. Non-zero means tagging discipline (OTEL_RESOURCE_ATTRIBUTES) is slipping.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 49
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{jira_epic=\"\", organization_id=~\"$organization_id\"}[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}